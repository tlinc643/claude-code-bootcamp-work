# Build output
slides/dist/
# Editor backups from slide reformatting
slides/*.classic.bak
# Single-file ebook is a build artifact; Leanpub source lives in book/leanpub/manuscript
book/dist/
# Track the rendered slide decks so learners can download them directly.
!slides/dist/
!slides/dist/pptx/
!slides/dist/pptx/**
!slides/dist/pdf/
!slides/dist/pdf/**
# Marp / build caches and gate logs are NOT tracked
slides/dist/.cache/
scripts/gates/*.log

# OS / editor
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/

# Misc
*.tmp
*.log
.env
.env.*
!.env.example
assessments/answer-key.md
.DS_Store
**/.DS_Store
.pytest_cache/
